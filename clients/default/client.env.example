# MAAI Agent Platform — Client Configuration
# Copy to client.env and fill in required values.
# Generate secrets: openssl rand -hex 32

# === Open WebUI ===
WEBUI_PORT=3000
WEBUI_SECRET_KEY=           # REQUIRED: generate with: openssl rand -hex 32

# === LiteLLM ===
LITELLM_MASTER_KEY=sk-maai-local   # Auth key for Open WebUI -> LiteLLM

# === GPU Control ===
# Auto-detected by bootstrap.sh. Override manually if needed.
OLLAMA_GPU_ENABLED=true     # Set to "false" to force CPU profile

# === Model Selection ===
# bootstrap.sh reads these. CPU profile auto-downgrades to smaller models.
REASONING_MODEL=qwen3:14b
CLASSIFIER_MODEL=gemma3:4b
EMBEDDING_MODEL=nomic-embed-text
